# authorized_keys — SSH public keys that can log into the Claude Code container
# as the `node` user over port 2222.
#
# Format: one key per line. Comments (#) allowed.
# Keep this file in git so changes are reviewable.
#
# Add a key by pasting it in the form:
#   ssh-ed25519 AAAA...base64... jos@device
#
# After editing this file and pushing, Portainer will redeploy the container
# and the key will be active on next SSH connect.

