From 560549fd863dbe8ec8b82b574bbdcbacf01aaaf5 Mon Sep 17 00:00:00 2001
From: Claude Code <claude-code@local>
Date: Sat, 11 Apr 2026 18:04:50 +0200
Subject: [PATCH] Add SSH on 2222 + parallel ttyd side session (claude-main +
 claude-side)

- Dockerfile: install openssh-server, bake sshd_config + authorized_keys,
  expose 7681 7682 2222, switch ENTRYPOINT to start-services.sh
- docker-compose.yml: point entrypoint at start-services.sh
- start-services.sh: orchestrates run-bot.sh (bg), sshd (2222), ttyd side (7682), ttyd main (7681 fg)
- attach-session-main.sh / attach-session-side.sh: two independent tmux sessions (claude-main, claude-side)
- ssh/sshd_config: minimal pubkey-only, node user, host keys persisted in /workspace/ai-cos/system/state/ssh-host-keys/
- ssh/authorized_keys: placeholder for Jos's public keys
---
 Dockerfile             | 23 ++++++++++---
 attach-session-main.sh | 12 +++++++
 attach-session-side.sh | 14 ++++++++
 docker-compose.yml     |  3 +-
 ssh/authorized_keys    | 15 +++++++++
 ssh/sshd_config        | 33 +++++++++++++++++++
 start-services.sh      | 73 ++++++++++++++++++++++++++++++++++++++++++
 7 files changed, 168 insertions(+), 5 deletions(-)
 create mode 100644 attach-session-main.sh
 create mode 100644 attach-session-side.sh
 create mode 100644 ssh/authorized_keys
 create mode 100644 ssh/sshd_config
 create mode 100644 start-services.sh

diff --git a/Dockerfile b/Dockerfile
index 3db2e84..2c393de 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -32,6 +32,7 @@ RUN apt-get update && apt-get install -y --no-install-recommends \
   libwebsockets-dev \
   libjson-c-dev \
   libssl-dev \
+  openssh-server \
   && apt-get clean && rm -rf /var/lib/apt/lists/*
 
 # Install ttyd binary for web terminal access
@@ -103,16 +104,30 @@ RUN chmod +x /usr/local/bin/init-firewall.sh && \
   echo "node ALL=(root) NOPASSWD: /usr/local/bin/init-firewall.sh" > /etc/sudoers.d/node-firewall && \
   chmod 0440 /etc/sudoers.d/node-firewall
 
-# Copy entrypoint and session attach script
+# Copy entrypoint, session attach scripts, and start-services orchestrator
 COPY entrypoint.sh /usr/local/bin/
 COPY attach-session.sh /usr/local/bin/
-RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/attach-session.sh
+COPY attach-session-main.sh /usr/local/bin/
+COPY attach-session-side.sh /usr/local/bin/
+COPY start-services.sh /usr/local/bin/
+RUN chmod +x /usr/local/bin/entrypoint.sh \
+              /usr/local/bin/attach-session.sh \
+              /usr/local/bin/attach-session-main.sh \
+              /usr/local/bin/attach-session-side.sh \
+              /usr/local/bin/start-services.sh
+
+# SSH server config (pubkey-only, port 2222) + authorized_keys baked into image
+COPY ssh/sshd_config /etc/ssh/sshd_config
+COPY ssh/authorized_keys /usr/local/share/ssh/authorized_keys
+RUN mkdir -p /run/sshd /home/node/.ssh && \
+    chown -R node:node /home/node/.ssh && \
+    chmod 700 /home/node/.ssh
 
 USER node
 
-EXPOSE 7681
+EXPOSE 7681 7682 2222
 
 HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
   CMD wget -q --spider http://127.0.0.1:7681/ || exit 1
 
-ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
+ENTRYPOINT ["/usr/local/bin/start-services.sh"]
diff --git a/attach-session-main.sh b/attach-session-main.sh
new file mode 100644
index 0000000..0061bf9
--- /dev/null
+++ b/attach-session-main.sh
@@ -0,0 +1,12 @@
+#!/bin/bash
+# attach-session-main.sh
+# Called by ttyd on port 7681 / Tailscale HTTPS 8443.
+# Attaches to the primary tmux session "claude-main" or creates it.
+
+TMUX_SESSION="claude-main"
+
+if su -s /bin/bash -c "tmux has-session -t $TMUX_SESSION" node 2>/dev/null; then
+  exec su -s /bin/bash -c "tmux attach-session -t $TMUX_SESSION" node
+else
+  exec su -s /bin/bash -c "tmux new-session -s $TMUX_SESSION 'claude --dangerously-skip-permissions; exec /bin/bash'" node
+fi
